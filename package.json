{
  "name": "seanorepo",
  "type": "module",
  "version": "0.0.1",
  "description": "monorepo for all sites, projects, etc",
  "main": "index.js",
  "repository": "https://github.com/seanmizen/seanorepo",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "utils/*"
  ],
  "scripts": {
    "sean": "yarn workspace seanmizen.com start",
    "caroline": "yarn workspace carolinemizen.art start",
    "cards": "yarn workspace seanscards start",
    "gosniff": "yarn workspace gosniff start",
    "converter": "yarn workspace ffmpeg-converter start",
    "voxel": "yarn workspace swindowzig native:voxel",
    "voxel:web": "yarn workspace swindowzig dev:voxel",
    "start:docker": "yarn workspaces foreach -Apt run start:docker",
    "prod:docker": "yarn workspaces foreach -At run prod:docker",
    "down": "yarn workspaces foreach -Apt run down",
    "check": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "fly:up": "docker compose -f utils/fly-io/docker-compose.fly.yml up --build --detach",
    "fly:down": "docker compose -f utils/fly-io/docker-compose.fly.yml down",
    "fly:deploy": "fly deploy",
    "prepare": "husky"
  },
  "packageManager": "yarn@4.8.1+sha512.bc946f2a022d7a1a38adfc15b36a66a3807a67629789496c3714dd1703d2e6c6b1c69ff9ec3b43141ac7a1dd853b7685638eb0074300386a59c18df351ef8ff6",
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.5.0",
    "husky": "^9.1.7"
  }
}
