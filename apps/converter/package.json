{
  "name": "converter",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["frontend"],
  "scripts": {
    "start": "concurrently --names FE,BE --prefix-colors cyan,green \"yarn workspace converter-fe start:noopen\" \"cd backend && go run .\"",
    "start:docker": "docker compose --profile dev up --build",
    "prod:docker": "BUILD_TARGET=prod docker compose --profile prod up --build --detach",
    "down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
