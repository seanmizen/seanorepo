# ao_corners.tas — Ambient-occlusion regression on a flatland deep hole.
#
# Purpose: dig a 1×3×1 vertical hole in flat terrain so the wall faces have
# interior edge vertices whose deeper neighbour cells (outward+2 plane)
# differ from their immediate face-plane neighbours. This is precisely the
# situation Moore-style AO darkens but classic Mojang AO misses, because
# classic only sees the single slab one cell beyond the face.
#
# Usage (from utils/swindowzig):
#   zig build native -Dexample=voxel
#   # NOTE: --aa=none and --render-distance=4 are passed explicitly so the
#   # post-default-change world defaults (AA=fxaa, AO=moore) don't contaminate
#   # the AO diff. The --ao= flag is the ONE variable that should move between
#   # these three captures.
#   ./zig-out/bin/voxel --world=flatland --aa=none --render-distance=4 --ao=none \
#     --tas examples/voxel/tests/ao_corners.tas \
#     --dump-frame=/tmp/ao_corners_none.ppm
#   ./zig-out/bin/voxel --world=flatland --aa=none --render-distance=4 --ao=classic \
#     --tas examples/voxel/tests/ao_corners.tas \
#     --dump-frame=/tmp/ao_corners_classic.ppm
#   ./zig-out/bin/voxel --world=flatland --aa=none --render-distance=4 --ao=moore \
#     --tas examples/voxel/tests/ao_corners.tas \
#     --dump-frame=/tmp/ao_corners_moore.ppm
#
# Tick numbering is relative to the first post-loading tick (TAS replayer
# is gated during world load), so tick 1 is always the first frame of
# gameplay.

# --- Capture mouse ---
1 mouse_down left
2 mouse_up left

# --- Look down so the flat grass surface is in view. ---
3 mouse_move 0 180

# --- Dig four blocks deep (1×4×1 vertical shaft).
#     After the first dig the crosshair pulls onto the floor of the hole;
#     subsequent digs eat downward. There's 1 tick between each dig so the
#     mouse-button edge fires cleanly. ---
5  mouse_down left
6  mouse_up left
8  mouse_down left
9  mouse_up left
11 mouse_down left
12 mouse_up left
14 mouse_down left
15 mouse_up left

# --- Pan rightward so the diagonal interior edges of the shaft are exposed
#     at an angle. 8 ticks of rightward pan @ 4px/tick = 32px total. ---
17 mouse_move 4 0
18 mouse_move 4 0
19 mouse_move 4 0
20 mouse_move 4 0
21 mouse_move 4 0
22 mouse_move 4 0
23 mouse_move 4 0
24 mouse_move 4 0

# --- Tilt up slightly so the rim of the hole is in frame too. ---
25 mouse_move 0 -50

# Hold steady so --dump-frame lands on a stable view.
30 mouse_move 0 0
